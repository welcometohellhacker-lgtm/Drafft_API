APP_NAME=Drafft API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/drafft
REDIS_URL=redis://redis:6379/0
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
DEFAULT_STYLE_PRESET=finance_clean
ENABLE_MOCK_PROVIDERS=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5
ELEVENLABS_API_KEY=
WEBHOOK_TIMEOUT_SECONDS=10
